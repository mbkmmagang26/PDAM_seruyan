rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Cek apakah user adalah admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/user_admin/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/user_admin/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Cek apakah user adalah accounting
    function isAccounting() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/user_admin/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/user_admin/$(request.auth.uid)).data.role == 'accounting';
    }

    // Helper: Cek apakah user adalah staff
    function isStaff() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/user_admin/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/user_admin/$(request.auth.uid)).data.role == 'staff' ||
         get(/databases/$(database)/documents/user_admin/$(request.auth.uid)).data.role == 'accounting' ||
         get(/databases/$(database)/documents/user_admin/$(request.auth.uid)).data.role == 'admin');
    }

    // Helper: Cek apakah dokumen milik user yang bersangkutan
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules: Koleksi tb_pelanggan (profil pelanggan)
    match /tb_pelanggan/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isStaff() || isAdmin() || isAccounting());
      // Pelanggan bisa register akun sendiri atau admin/staff bisa membuat/mengedit
      allow write: if isOwner(userId) || isAdmin() || isAccounting();
    }

    // Rules: Koleksi user_admin (akun admin, staff, accounting)
    match /user_admin/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isAdmin() || isAccounting());
      // Hanya admin yang bisa membuat atau memodifikasi akun staff/admin lain
      allow write: if isAdmin() || isOwner(userId);
    }

    // Rules: Koleksi pengaduan_pelanggan
    match /pengaduan_pelanggan/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isStaff() || isAdmin() || isAccounting());
      // Pelanggan bisa menulis pengaduan baru, admin/staff bisa update status
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isStaff() || isAdmin() || isAccounting());
      allow delete: if isAdmin();
    }

    // Rules: Koleksi tb_permohonan (pemasangan baru)
    match /tb_permohonan/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isAccounting());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isAccounting();
    }

    // Rules: Koleksi tb_billing (tagihan air)
    match /tb_billing/{docId} {
      allow read: if request.auth != null && (resource.data.customerId == request.auth.uid || isAdmin() || isAccounting() || isStaff());
      // Hanya admin/accounting yang bisa create, update, delete tagihan
      allow write: if isAdmin() || isAccounting();
    }

    // Rules: Koleksi tb_meter_pelanggan (pembacaan meteran)
    match /tb_meter_pelanggan/{docId} {
      allow read: if request.auth != null && (resource.data.customerId == request.auth.uid || isStaff() || isAdmin() || isAccounting());
      // Hanya staff lapangan atau admin/accounting yang bisa write
      allow write: if request.auth != null && (isStaff() || isAdmin() || isAccounting());
    }

    // Rules: Koleksi inventory & assets
    match /inventory/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isAccounting();
    }
    match /assets/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isAccounting();
    }

    // Rules: Koleksi log aktivitas
    match /tb_activity_user_admin/{docId} {
      allow read: if request.auth != null && (isAdmin() || isAccounting());
      allow create: if request.auth != null;
      allow update, delete: if false; // Log tidak boleh dimodifikasi/dihapus
    }
    match /customer_activity/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isAccounting());
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Rules: Koleksi notifications
    match /notifications/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userId == 'all' || isAdmin() || isAccounting());
      allow write: if request.auth != null && (isStaff() || isAdmin() || isAccounting());
    }
  }
}
